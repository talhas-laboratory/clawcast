{
  "name": "@talhas-laboratory/clawcast",
  "version": "1.0.2",
  "description": "ClawCast for OpenClaw: cast/persona management with shared context and Cast Manager UI",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "node --check dist/index.js && find src -type f -name \"*.js\" -print0 | xargs -0 -r -n1 node --check",
    "lint": "node --check dist/index.js && find src -type f -name \"*.js\" -print0 | xargs -0 -r -n1 node --check",
    "test": "node --test tests/*.test.js"
  },
  "files": [
    "dist/",
    "src/",
    "static/",
    "openclaw.plugin.json",
    "INSTALL.md",
    "AGENT-INSTALL-REFERENCE.md",
    "README.md",
    "SECURITY.md",
    "RELEASING.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "keywords": [
    "openclaw",
    "clawcast",
    "cast",
    "persona",
    "agent",
    "memory",
    "miniapp"
  ],
  "author": "talhas laboratory",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talhas-laboratory/clawcast.git"
  },
  "bugs": {
    "url": "https://github.com/talhas-laboratory/clawcast/issues"
  },
  "homepage": "https://github.com/talhas-laboratory/clawcast#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
